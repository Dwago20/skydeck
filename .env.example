# ─── Database ────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── AWS Credentials (Optional) ─────────────────────────────
# When set, SkyDeck connects to your real AWS account.
# Without these, the app uses seeded demo data.
#
# AWS_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── Azure Credentials (Optional) ───────────────────────────
# When set, SkyDeck connects to your real Azure account.
# Without this, the app uses seeded demo data.
#
# AZURE_STORAGE_CONNECTION_STRING=
